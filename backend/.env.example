# ====================================
# Anonim Oylama Backend - Örnek Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.
# ====================================

# Sunucu Ayarları
SERVER_PORT=8080

# PostgreSQL Bağlantı Ayarları
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=anonim_oylama
DB_SSLMODE=disable

# JWT Ayarları
JWT_SECRET=your-secret-key-here

# SMTP (E-posta) Ayarları
# Gmail için "Uygulama Şifresi" (App Password) oluşturmanız gerekir.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@anonimoylama.com
