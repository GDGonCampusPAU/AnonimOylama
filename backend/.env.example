# ====================================
# Anonim Oylama Backend - Örnek Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.
# ====================================

# Sunucu Ayarları
SERVER_PORT=8080

# PostgreSQL Bağlantı Ayarları
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=anonim_oylama
DB_SSLMODE=disable

# JWT Ayarları
JWT_SECRET=your-secret-key-here
